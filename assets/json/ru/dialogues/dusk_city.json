{
	"start": {
		"nodes": [
			{
				"type": "phrase",
				"speaker": "dusk",
				"text": "В это время, другая пони, у которой в тот день был выходной…",
			},
			{
				"type": "phrase",
				"speaker": "pay",
				"state": "sus",
				"text": "Эй, а она еще больше похожа на тебя!",
			},
			{
				"type": "phrase",
				"speaker": "bowler_hat",
				"state": "smirk",
				"text": "Да, точно! Признай, это же буквально ты.",
			},
			{
				"type": "phrase",
				"speaker": "dusk",
				"state": "confused",
				"text": "Да не было там…",
			},
			{
				"type": "phrase",
				"speaker": "dusk",
				"state": "serious",
				"text": "Ладно, если вам так будет проще",
			},
			{
				"type": "phrase",
				"speaker": "dusk",
				"state": "serious",
				"text": "Я, у которой в тот день был выходной",
			},
			{
				"type": "phrase",
				"speaker": "dusk",
				"state": "idle",
				"text": "Прогуливалась по городу и совершенно не подозревала, что её",
			},
			{
				"type": "phrase",
				"speaker": "dusk",
				"state": "confused",
				"text": "…меня…",
			},
			{
				"type": "phrase",
				"speaker": "dusk",
				"state": "idle",
				"text": "…ждет дальше.",
			},
		]
	},
