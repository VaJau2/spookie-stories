[sub_resource type="GDScript" id="GDScript_emqnb"]
script/source = "extends Node

@export var exit_label: Label


func set_label_visible() -> void:
	exit_label.visible = true
	set_process(true)


func _ready() -> void:
	set_process(false)


func _process(delta: float) -> void:
	if exit_label.modulate.a < 1:
		exit_label.modulate.a += delta
"

