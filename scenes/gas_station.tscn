[sub_resource type="GDScript" id="GDScript_4o66k"]
script/source = "extends Node2D

@onready var empty: Node2D = get_node(\"empty\")
@onready var station: Node2D = get_node(\"station\")

var skip_showing: bool = false
var showed: bool = false


func set_skip_showing() -> void:
	skip_showing = true


func _on_visibility_changed() -> void:
	if showed: return
	
	if !visible:
		if empty.visible && !skip_showing:
			empty.visible = false
			station.visible = true
		else:
			empty.visible = true
			station.visible = false
			showed = true
"

