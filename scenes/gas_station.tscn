[sub_resource type="GDScript" id="GDScript_3qfvt"]
script/source = "extends Area2D

@export var inside_station_scenario: Node
@export var dialogue_menu: DialogueMenu

var is_active: bool = false

var controller: MovementController


func _on_body_entered(body: Node2D) -> void:
	if !is_active: return
	var dialogue_file = \"gas_station\"
	
	if body.name == \"bowler_hat\":
		var code = \"\"
		
		if inside_station_scenario.counter == 1:
			code = \"pump_forgot\"
		elif inside_station_scenario.counter == 2:
			code = \"pump_ready\"
		
		if code != \"\": 
			dialogue_menu.start_dialogue(dialogue_file, code)
			controller = body.get_node(\"movement_controller\")
			controller.may_move = false
			dialogue_menu.finished_dialogue.connect(_on_finished_dialogue)


func _on_finished_dialogue() -> void:
	controller.may_move = true
	dialogue_menu.finished_dialogue.disconnect(_on_finished_dialogue)
	is_active = false
	if inside_station_scenario.counter == 2:
		queue_free()
"

