[sub_resource type="GDScript" id="GDScript_rmk5d"]
script/source = "extends Node

@export var ghosts_anim: AnimationPlayer
@export var ghosts: Array[Node2D]
@export var ghosts_timers: Array[float]
@export var dialogue_menu: DialogueMenu
@export var player_name: String
@export var pop_audi: AudioStreamPlayer

var timer: float = 0
var step: int = 0


func delete() -> void:
	ghosts_anim.pause()
	timer = ghosts_timers[0]
	set_process(true)


func _ready() -> void:
	set_process(false)


func _process(delta: float) -> void:
	if timer > 0:
		timer -= delta
	else:
		timer = ghosts_timers[step]
		if step != 0: 
			pop_audi.play()
			ghosts[step - 1].visible = false
		
		step += 1
		if step >= len(ghosts_timers): 
			dialogue_menu.start_dialogue(\"gas_station\", \"ghosts2\")
			dialogue_menu.finished_dialogue.connect(_on_finished_dialogue)
			set_process(false)
			return

func _on_finished_dialogue() -> void:
	await get_tree().create_timer(0.5).timeout
	dialogue_menu.finished_dialogue.disconnect(_on_finished_dialogue)
	var player = get_node(\"/root/main/\" + player_name)
	var movement_controller: MovementController = player.get_node(\"movement_controller\")
	movement_controller.may_move = true
"

[sub_resource type="GDScript" id="GDScript_65dx5"]
script/source = "extends Node

@export_category(\"cash\")
@export var cash: Sprite2D
@export var audi: AudioStreamPlayer2D

@export_category(\"canister\")
@export var canister_sprite: Sprite2D
@export var pump_sprite: Sprite2D
@export var pump_idle_texture: Texture
@export var pump_working_texture: Texture
@export var outside_canister: Sprite2D

@export_category(\"refuel_sound\")
@export var refuel_audi: AudioStreamPlayer2D
@export var refuel_start: AudioStream
@export var refuel_process: AudioStream
@export var refuel_end: AudioStream

@export_category(\"refuel_logic\")
@export var pump_dialogue_area: Area2D
@export var counter: int = 0


func put_cash() -> void:
	cash.visible = true
	audi.play()
	counter += 1
	pump_dialogue_area.is_active = true


func take_canister() -> void:
	canister_sprite.visible = false
	counter += 1
	pump_dialogue_area.is_active = true


func set_pump_working() -> void:
	pump_sprite.texture = pump_working_texture
	outside_canister.visible = true
	refuel_audi.stream = refuel_start
	refuel_audi.play()


func process_refuel() -> void:
	refuel_audi.stream = refuel_process
	refuel_audi.play()


func end_refuel() -> void:
	refuel_audi.stream = refuel_end
	refuel_audi.play()
	pump_sprite.texture = pump_idle_texture
	outside_canister.visible = false
"

